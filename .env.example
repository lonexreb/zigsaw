# ──────────────────────────────────────────────────────────────
# Zigsaw — environment template
# Copy to `.env.local` (gitignored) and fill in your values.
# Do NOT commit any populated copy of this file.
# ──────────────────────────────────────────────────────────────

# ============= AI providers =============
# At least one of the following is required for chat-to-workflow + execution.
# In production, these live in the API backend and are NEVER shipped to the browser.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# Frontend dev fallbacks. Loaded by Vite as `import.meta.env.VITE_*`.
# Only populate these for *local development*. Real keys belong on the backend.
VITE_ANTHROPIC_API_KEY=
VITE_OPENAI_API_KEY=
VITE_GROQ_API_KEY=

# ============= Firebase =============
# Used by both frontend (auth) and backend (admin SDK).

FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Path to the Firebase Admin service account JSON. Keep this file *outside* the repo
# or under `secrets/` (gitignored).
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./secrets/firebase-service-account.json

# Frontend Firebase config (Vite vars — public by design, but still env-driven).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ============= Stripe (billing) =============
# Publishable key is safe to expose; secret key is server-only.

VITE_STRIPE_PUBLIC_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ============= Integrations =============

# GitHub Personal Access Token (used by GitHub MCP server / co-pilot track).
GITHUB_PAT=
# Default repo for the GitHub agent (optional: owner/repo).
GITHUB_REPO=

# Firecrawl
FIRECRAWL_API_KEY=

# Google Cloud (Calendar, Veo3, Imagen, etc.)
GOOGLE_APPLICATION_CREDENTIALS=./secrets/gcp-service-account.json

# ============= App URLs =============
# Frontend → backend wiring.

VITE_API_URL=http://localhost:3000
VITE_BACKEND_URL=http://localhost:3000

# Public-facing app URL (used by Stripe callbacks, OAuth redirects).
PUBLIC_APP_URL=http://localhost:8081

# ============= Runtime =============
NODE_ENV=development
LOG_LEVEL=info

# Set to true to enable extra debug logging in workflow execution + AI provider routing.
DEBUG=false
